# ===================================================
# AI Resume Builder - Backend Environment Variables
# ===================================================
# Copy this file to .env and fill in your values.

# ---------------------------------------------------
# DEFAULT GROQ API KEY (Required)
# Get your free key at: https://console.groq.com
# This key is used for the free tier (rate-limited).
# ---------------------------------------------------
GROQ_API_KEY=your_groq_api_key_here

# ---------------------------------------------------
# Default model to use (optional, can be overridden)
# Recommended: llama-3.3-70b-versatile or mixtral-8x7b-32768
# ---------------------------------------------------
GROQ_MODEL=llama-3.3-70b-versatile

# ---------------------------------------------------
# Server config
# ---------------------------------------------------
PORT=3001
NODE_ENV=development

# ---------------------------------------------------
# Rate limiting for free tier (requests per 15 minutes)
# ---------------------------------------------------
FREE_TIER_RATE_LIMIT=15
